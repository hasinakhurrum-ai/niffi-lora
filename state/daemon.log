metrics = performance_monitoring_system.get_metrics()
for metric, values in metrics.items():
    print(f"{metric}: {sum(values) / len(values)}")

resource_allocator = ResourceAllocator(5)
resource_allocator.allocate_resources([1, 2, 3])
```

