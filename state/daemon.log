        try:
            # Ensure the bot's virtual environment is set up
            self.ensure_bot_venv(bot_id)
            
            # Create a workspace for the run
            run_workspace = self.get_run_workspace(bot_id)
            os.makedirs(run_workspace, exist_ok=True)
            
            # Write the candidate code to a file
            with open(os.path.join(run_workspace, 'candidate.py'), 'w') as f:
                f.write(code)
            
            # Run the candidate code using the virtual environment
            command = [
                os.path.join('bots', bot_id, 'venv/bin/python3'),
                '-m',
                'ollama_client',
                'generate',
                '--model',
                'mistral-7b-v1.5',
                '--prompt',
                f"Write a Python function that takes two numbers as input and returns their sum."
            ]
            
            # Capture the output and error
            result = subprocess.run(command, capture_output=True, text=True, check=True)
            
            # Log the output for debugging
            self.logger.debug(f"Output: {result.stdout}")
            
            return result.stdout.strip()
        
        except Exception as e:
            # Log any exceptions that occur
            self.logger.error(f"Error running candidate code: {e}")
            raise

