import sqlite3

class DatabaseHandler:
    @staticmethod
    def connect():
        try:
            connection = sqlite3.connect('database.db')
            connection.execute("PRAGMA foreign_keys = 1")
            return connection
        except Exception as e:
            ErrorHandler.log_error("Failed to connect to database", e)
            raise

    @staticmethod
    def query(sql, params=None):
        connection = DatabaseHandler.connect()
        try:
            cursor = connection.cursor()
            if params is not None:
                cursor.execute(sql, params)
            else:
                cursor.execute(sql)

            result = cursor.fetchall()
            return result
        except sqlite3.Error as e:
            ErrorHandler.log_error("Database query error", e)
            raise
        finally:
            connection.close()

    @staticmethod
    def execute(sql, params=None):
        connection = DatabaseHandler.connect()
        try:
            cursor = connection.cursor()
            if params is not None:
                cursor.execute(sql, params)
            else:
                cursor.execute(sql)

            connection.commit()
        except sqlite3.Error as e:
            ErrorHandler.log_error("Database execution error", e)
            raise
        finally:
            connection.close()
